<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Titulo de la app -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗳️ Elecciones Alcaldía"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistema de votación municipal"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="28dp"/>

        <!-- ══════════ PANEL 1: Configuración ══════════ -->
        <LinearLayout
            android:id="@+id/panelConfiguracion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configuración de la elección"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número total de electores:"
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etNumeroElectores"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ej: 50"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnIniciarEleccion"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Iniciar elección"
                android:layout_marginTop="16dp"
                android:backgroundTint="#1A237E"
                android:textColor="#FFFFFF"
                android:textSize="15sp"/>

        </LinearLayout>

        <!-- ════════ PANEL 2: Para Votación ══════════ -->
        <LinearLayout
            android:id="@+id/panelVotacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTurnoElector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elector 1 de 10"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edad del elector (años):"
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etEdadElector"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ingrese la edad"
                android:inputType="number"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:textSize="16sp"/>

            <!-- Mensaje de menor de edad oculto por defecto -->
            <TextView
                android:id="@+id/tvMensajeInhabilitado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Elector menor de edad. No puede votar."
                android:textSize="14sp"
                android:textColor="#B71C1C"
                android:background="#FFEBEE"
                android:padding="12dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

            <!-- Selección de candidatos ( va a estar oculto hasta validar edad) -->
            <LinearLayout
                android:id="@+id/panelCandidatos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccione su candidato:"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:layout_marginBottom="8dp"/>

                <RadioGroup
                    android:id="@+id/rgCandidatos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbCandidato1"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="👤  Candidato 1 — Juan Pérez"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:buttonTint="#1A237E"/>

                    <RadioButton
                        android:id="@+id/rbCandidato2"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="👤  Candidato 2 — María Gómez"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:buttonTint="#1A237E"/>

                    <RadioButton
                        android:id="@+id/rbCandidato3"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="👤  Candidato 3 — Carlos López"
                        android:textSize="15sp"
                        android:gravity="center_vertical"
                        android:buttonTint="#1A237E"/>

                </RadioGroup>

            </LinearLayout>

            <!-- Botones de acción edad y voto-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:gravity="end">

                <Button
                    android:id="@+id/btnValidarEdad"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="Verificar edad"
                    android:backgroundTint="#37474F"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnRegistrarVoto"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="Registrar voto"
                    android:backgroundTint="#1A237E"
                    android:textColor="#FFFFFF"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

        <!-- ═════════ PANEL 3: Resultados ══════════ -->
        <LinearLayout
            android:id="@+id/panelResultados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:elevation="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Resultados finales"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#1A237E"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvResultados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:lineSpacingMultiplier="1.6"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvGanador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#1A237E"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnNuevaEleccion"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Nueva elección"
                android:backgroundTint="#37474F"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>